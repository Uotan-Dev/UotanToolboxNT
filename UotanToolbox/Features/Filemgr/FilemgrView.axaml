<UserControl x:Class="UotanToolbox.Features.Filemgr.FilemgrView"
			 xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:filemgr="clr-namespace:UotanToolbox.Features.Filemgr"
			 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
			 xmlns:theme="clr-namespace:SukiUI.Theme;assembly=SukiUI"
			 xmlns:assets="clr-namespace:UotanToolbox.Assets;assembly=UotanToolbox"
			 d:DesignWidth="1024"
			 d:DesignHeight="800"
			 x:DataType="filemgr:FilemgrViewModel"
			 x:Name="RootView"
			 mc:Ignorable="d">
	<ScrollViewer VerticalScrollBarVisibility="Hidden">
		<StackPanel Margin="10 10 0 10" Orientation="Horizontal">
			<suki:GlassCard Margin="10" Width="225" Height="760">
				<StackPanel Orientation="Vertical" Spacing="0">
					<TextBlock HorizontalAlignment="Left"
							   VerticalAlignment="Top"
							   FontWeight="DemiBold"
							   Text="{x:Static assets:Resources.Filemgr_QuickAccess}" />
					<ItemsControl Margin="0 10 0 0" Height="670" ItemsSource="{Binding QuickAccessItems}" x:CompileBindings="False">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Classes="Outlined" Height="30" Padding="0" BorderThickness="0"
										Command="{Binding DataContext.NavigateToQuickAccessCommand, ElementName=RootView}"
										CommandParameter="{Binding}" HorizontalContentAlignment="Left"
										FontWeight="{Binding IsActive, Converter={x:Static filemgr:BoolToFontWeightConverter.Instance}}">
									<Button.ContextMenu>
										<ContextMenu>
											<MenuItem Header="{x:Static assets:Resources.Filemgr_Delete}"
													  Command="{Binding DataContext.RemoveFromQuickAccessCommand, ElementName=RootView}"
													  CommandParameter="{Binding}"/>
										</ContextMenu>
									</Button.ContextMenu>
									<ToolTip.Tip>
										<TextBlock Text="{Binding Path}"/>
									</ToolTip.Tip>
									<TextBlock Margin="10 0 0 0">
										<avalonia:MaterialIcon Kind="{Binding Icon}" />
										<TextBlock Text="{Binding Name}"/>
									</TextBlock>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
					<CheckBox HorizontalAlignment="Center" IsChecked="{Binding UseROOT}" Command="{Binding SetRootModeCommand}" Content="{x:Static assets:Resources.Filemgr_RootMode}"/>
				</StackPanel>
			</suki:GlassCard>

			<suki:GlassCard Margin="5 10" Width="730" Height="760">
				<suki:BusyArea BusyText="{x:Static assets:Resources.Filemgr_BusyText}" IsBusy="{Binding IsBusy}">
					<StackPanel>
						<StackPanel Orientation="Horizontal" Spacing="5">
							<Button Margin="5 0 0 0" Classes="Outlined" Height="30" Width="30" Padding="0" BorderThickness="0"
									Command="{Binding NavigateUpCommand}" IsEnabled="{Binding CanNavigateUp}" ToolTip.Tip="{x:Static assets:Resources.Filemgr_NavigateUp}">
								<avalonia:MaterialIcon Kind="ArrowUp" Padding="5"/>
							</Button>
							<Button Margin="5 0 0 0" Classes="Outlined" Height="30" Width="30" Padding="0" BorderThickness="0"
									Command="{Binding RefreshCommand}" ToolTip.Tip="{x:Static assets:Resources.Home_Refresh}">
								<avalonia:MaterialIcon Kind="Refresh" Padding="5"/>
							</Button>
							<TextBox Width="520" Text="{Binding PathInput, Mode=TwoWay}">
								<TextBox.KeyBindings>
									<KeyBinding Gesture="Enter" Command="{Binding NavigateToPathCommand}"/>
								</TextBox.KeyBindings>
							</TextBox>
							<Button Margin="5 0 0 0" Classes="Outlined" Height="30" Width="30" Padding="0" BorderThickness="0"
									Command="{Binding PushFileCommand}"
									ToolTip.Tip="{x:Static assets:Resources.Filemgr_Import}">
								<avalonia:MaterialIcon Kind="UploadOutline" Padding="5"/>
							</Button>
							<Button Margin="5 0 0 0" Classes="Outlined" Height="30" Width="30" Padding="0" BorderThickness="0"
									Command="{Binding PullFileCommand}" CommandParameter="{Binding SelectedFile}"
									ToolTip.Tip="{x:Static assets:Resources.Filemgr_Export}">
								<avalonia:MaterialIcon Kind="DownloadOutline" Padding="5"/>
							</Button>
							<Button Margin="5 0 0 0" Classes="Outlined" Height="30" Width="30" Padding="0" BorderThickness="0"
									Command="{Binding DeleteSelectedCommand}"
									ToolTip.Tip="{x:Static assets:Resources.Filemgr_Delete}">
								<avalonia:MaterialIcon Kind="DeleteOutline" Padding="5"/>
							</Button>
						</StackPanel>
						<suki:GlassCard Height="672">
							<suki:GlassCard.ContextMenu>
								<ContextMenu>
									<MenuItem Header="{x:Static assets:Resources.Filemgr_New}">
										<MenuItem Header="{x:Static assets:Resources.Filemgr_File}" Command="{Binding NewFileCommand}"/>
										<MenuItem Header="{x:Static assets:Resources.Filemgr_Folder}" Command="{Binding NewFolderCommand}"/>
									</MenuItem>
									<MenuItem Header="{x:Static assets:Resources.Filemgr_Send}">
										<MenuItem Header="{x:Static assets:Resources.Filemgr_File}" Command="{Binding PushFileCommand}"/>
										<MenuItem Header="{x:Static assets:Resources.Filemgr_Folder}" Command="{Binding PushFolderCommand}"/>
									</MenuItem>
									<MenuItem Header="{x:Static assets:Resources.Filemgr_Paste}"
											  Command="{Binding PasteFileCommand}"
											  IsEnabled="{Binding CanPaste}"/>
									<Separator/>
									<MenuItem Header="{x:Static assets:Resources.Home_Refresh}" Command="{Binding RefreshCommand}"/>
								</ContextMenu>
							</suki:GlassCard.ContextMenu>
							<ScrollViewer>
								<WrapPanel>
									<TextBlock Text="{x:Static assets:Resources.Filemgr_EmptyList}" Classes="h4" Margin="15,15,15,15"
											   IsVisible="{Binding !HasLoaded}" HorizontalAlignment="Left"/>
									<ItemsControl Name="FileView" ItemsSource="{Binding Files}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<VirtualizingStackPanel Orientation="Vertical" />
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<suki:GlassCard Margin="5 10 5 0" Padding="0" CornerRadius="10" IsInteractive="True" DoubleTapped="OnFileEntryDoubleTapped">
													<suki:GlassCard.ContextMenu>
														<ContextMenu x:CompileBindings="False">
															<MenuItem Header="{x:Static assets:Resources.Filemgr_Open}"
																	  Command="{Binding DataContext.OpenFileEntryCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_Copy}"
																	  Command="{Binding DataContext.CopyFileCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_Cut}"
																	  Command="{Binding DataContext.CutFileCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_Delete}"
																	  Command="{Binding DataContext.DeleteFileCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_Rename}"
																	  Command="{Binding DataContext.RenameFileCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<Separator/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_AddToQuickAccess}"
																	  Command="{Binding DataContext.AddToQuickAccessCommand, ElementName=RootView}"
																	  CommandParameter="{Binding}"/>
															<MenuItem Header="{x:Static assets:Resources.Filemgr_ExtractTo}">
																<MenuItem Header="{x:Static assets:Resources.Filemgr_Desktop}"
																		  Command="{Binding DataContext.ExtractToDesktopCommand, ElementName=RootView}"
																		  CommandParameter="{Binding}"/>
																<MenuItem Header="{x:Static assets:Resources.Filemgr_Downloads}"
																		  Command="{Binding DataContext.ExtractToDownloadsCommand, ElementName=RootView}"
																		  CommandParameter="{Binding}"/>
																<MenuItem Header="{x:Static assets:Resources.Filemgr_CustomDir}"
																		  Command="{Binding DataContext.ExtractToCustomDirCommand, ElementName=RootView}"
																		  CommandParameter="{Binding}"/>
															</MenuItem>
														</ContextMenu>
													</suki:GlassCard.ContextMenu>
													<CheckBox Margin="10 0 0 0" IsChecked="{Binding IsSelected}">
														<Border Padding="0 5" Background="Transparent">
															<StackPanel Orientation="Horizontal">
																<Image Width="40"
																	   Height="40"
																	   Margin="0"
																	   Source="{Binding IconSource}" />
																<TextBlock FontSize="15" Margin="10 10 0 0" FontWeight="DemiBold" HorizontalAlignment="Center" Width="205" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding DisplayName}"/>
																<TextBlock FontSize="15" Margin="10 10 0 0" FontWeight="DemiBold" HorizontalAlignment="Center" Width="60" Text="{Binding DisplaySize}"/>
																<TextBlock FontSize="15" Margin="10 10 0 0" FontWeight="DemiBold" HorizontalAlignment="Center" Width="90" Text="{Binding Permission}"/>
																<TextBlock FontSize="15" Margin="10 10 0 0" FontWeight="DemiBold" HorizontalAlignment="Center" Width="150" Text="{Binding ModifiedTime}"/>
															</StackPanel>
														</Border>
													</CheckBox>
												</suki:GlassCard>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</WrapPanel>
							</ScrollViewer>
						</suki:GlassCard>
					</StackPanel>
				</suki:BusyArea>
			</suki:GlassCard>
		</StackPanel>
	</ScrollViewer>
</UserControl>
